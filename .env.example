# ===========================================================
# InkScroller Flutter — dart-define reference
# ===========================================================
# Flutter does NOT use .env files natively.
# This file documents the --dart-define variables used per flavor.
#
# HOW TO USE LOCALLY:
#   Pass these as --dart-define flags when running the app, or
#   use the .run/ configs in Android Studio (already committed).
#
# HOW TO USE IN CI:
#   Store values as GitHub Secrets and pass them to the build step.
#   See SECURITY_PUBLIC_READINESS.md §3 for full CI instructions.
#
# NEVER create a real .env file with secrets — .dart-defines/ is
# already excluded by .gitignore for local overrides.
# ===========================================================

# -- API Base URL (per flavor) --------------------------------
# The backend custom domain for each environment.
# These are passed via --dart-define=API_BASE_URL=<url>
# dev:     https://api.dev.inkscroller.devdigi.dev
# staging: https://api.stg.inkscroller.devdigi.dev
# pro:     https://api.inkscroller.devdigi.dev
API_BASE_URL=https://api.dev.inkscroller.devdigi.dev

# -- Firebase Config ------------------------------------------
# Firebase config is NOT passed via dart-define.
# It is injected at build time via google-services.json (Android)
# and GoogleService-Info.plist (iOS).
# See docs/firebase-config-example.md for file structure.
# See SECURITY_PUBLIC_READINESS.md §3 for CI injection steps.
