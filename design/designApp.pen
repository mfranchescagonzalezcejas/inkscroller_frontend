          "cornerRadius": 16,
          "layout": "vertical",
          "gap": 10,
          "padding": 16,
          "children": [
            {
              "type": "text",
              "id": "L8zxwf",
              "name": "priorityTitle",
              "fill": "#0B1718",
              "content": "Recommended Light Mode Order",
              "fontFamily": "Plus Jakarta Sans",
              "fontSize": 18,
              "fontWeight": "700"
            },
            {
              "type": "text",
              "id": "C8CEH",
              "name": "priorityText",
              "fill": "#0B1718",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "1. Add light tokens as direct mappings from dark tokens.\n2. Keep dark mode as default; expose light mode as preference.\n3. Audit Settings/About/Auth first because they are surface-heavy.\n4. Validate Explore/Library cards against cover artwork.\n5. Review runtime states for calm contrast and accessible CTAs.",
              "lineHeight": 1.5,
              "fontFamily": "Plus Jakarta Sans",
              "fontSize": 13,
              "fontWeight": "600"
            }
          ]
        }
      ]
