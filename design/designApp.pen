        {
          "type": "frame",
          "id": "uxY1J",
          "name": "Flutter layout notes",
          "width": "fill_container",
          "fill": "#FFFFFF",
          "cornerRadius": 16,
          "layout": "vertical",
          "gap": 10,
          "padding": 16,
          "children": [
            {
              "type": "text",
              "id": "y6eFgQ",
              "name": "platformTitle",
              "fill": "#0B1718",
              "content": "Flutter light mode notes",
              "fontFamily": "Plus Jakarta Sans",
              "fontSize": 18,
              "fontWeight": "700"
            },
            {
              "type": "text",
              "id": "p9OhBA",
              "name": "platformText",
              "fill": "#526264",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "Dark mode remains the default and source of truth. Light mode maps every original token to a bright equivalent: Void Light #F8FBFA, Stage Light #DDEBE8, Glass Light #CFE0DC, Card Light #FFFFFF, Card High Light #C1D7D2, Outline Light #7F918E. Use the light theme only through an explicit user preference.",
              "lineHeight": 1.5,
              "fontFamily": "Plus Jakarta Sans",
              "fontSize": 13,
              "fontWeight": "500"
            }
          ]
        },
        {
          "type": "frame",
          "id": "d2ah1l",
          "name": "Typography and spacing",
          "width": "fill_container",
          "gap": 18,
          "children": [
            {
              "type": "frame",
              "id": "rKFC7",
              "name": "typo",
              "width": "fill_container",
              "fill": "#DCEAE7",
              "cornerRadius": 16,
              "layout": "vertical",
              "gap": 10,
              "padding": 16,
              "children": [
                {
                  "type": "text",
                  "id": "DF801",
                  "name": "typoTitle",
                  "fill": "#0B1718",
                  "content": "Typography",
                  "fontFamily": "Plus Jakarta Sans",
                  "fontSize": 18,
                  "fontWeight": "700"
                },
                {
                  "type": "text",
                  "id": "g8D5oB",
                  "name": "typoText",
                  "fill": "#526264",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "Font: Plus Jakarta Sans\nDisplay/Auth: 38–44 / 700\nScreen title: 28–32 / 700\nSection title: 18–22 / 700\nBody: 14–16 / 400–500\nMeta: 11–13 / 500\nText token: Text Light #061314\nMuted token: Muted Light #5B6769",
                  "lineHeight": 1.5,
                  "fontFamily": "Plus Jakarta Sans",
                  "fontSize": 13,
                  "fontWeight": "500"
                }
              ]
            },
            {
              "type": "frame",
              "id": "THZCg",
              "name": "spacing",
              "width": "fill_container",
              "fill": "#DCEAE7",
              "cornerRadius": 16,
              "layout": "vertical",
              "gap": 10,
              "padding": 16,
              "children": [
                {
                  "type": "text",
                  "id": "MQA1r",
                  "name": "spacingTitle",
                  "fill": "#0B1718",
                  "content": "Spacing + Radius",
                  "fontFamily": "Plus Jakarta Sans",
                  "fontSize": 18,
                  "fontWeight": "700"
                },
                {
                  "type": "text",
                  "id": "eTA6q",
                  "name": "spacingText",
                  "fill": "#526264",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "Scale: 4 / 8 / 12 / 16 / 24 / 32 / 40 / 48\nCards: 16–20 padding\nSections: 24–32 gap\nEditorial blocks: 40–48\nRadius: 12 inputs, 16 cards, 20 hero, 28 nav\nSurfaces: Card Light over Stage Light",
                  "lineHeight": 1.5,
                  "fontFamily": "Plus Jakarta Sans",
                  "fontSize": 13,
                  "fontWeight": "500"
                }
              ]
            }
          ]
        },
        {
          "type": "frame",
          "id": "ptAMD",
          "name": "Cinematic rules",
          "width": "fill_container",
          "fill": "#DCEAE7",
          "cornerRadius": 16,
          "layout": "vertical",
          "gap": 10,
          "padding": 16,
          "children": [
            {
              "type": "text",
              "id": "ZSSvQ",
              "name": "principlesTitle",
              "fill": "#0B1718",
              "content": "Light Canvas Rules",
              "fontFamily": "Plus Jakarta Sans",
              "fontSize": 18,
              "fontWeight": "700"
            },
            {
              "type": "text",
              "id": "Fe3Ai",
              "name": "principlesText",
              "fill": "#526264",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "The rule is role parity: each light token must be as distinguishable from its neighbors as the dark token is in the original palette. If Void Light, Stage Light, Glass Light and Card Light collapse visually, the light mode fails.",
              "lineHeight": 1.5,
              "fontFamily": "Plus Jakarta Sans",
              "fontSize": 13,
              "fontWeight": "500"
            }
          ]
        },
        {
          "type": "frame",
          "id": "VoRMZ",
          "name": "Component contracts",
          "width": "fill_container",
          "fill": "#FFFFFF",
          "cornerRadius": 16,
          "layout": "vertical",
          "gap": 10,
          "padding": 16,
          "children": [
            {
              "type": "text",
              "id": "mn4Sh",
              "name": "componentsTitle",
              "fill": "#0B1718",
              "content": "Component Contracts to Add",
              "fontFamily": "Plus Jakarta Sans",
              "fontSize": 18,
              "fontWeight": "700"
            },
            {
              "type": "text",
              "id": "INgvR",
              "name": "componentsText",
              "fill": "#526264",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "• TonalTabBar: active via Card High Light #C1D7D2 + Primary Light #2FAFA3 text/weight.\n• Cards: use Card Light #FFFFFF over Stage Light #DDEBE8 or Void Light #F8FBFA.\n• Glass: use Glass Light #CFE0DC only for translucent/floating controls.\n• AuthField: Card Light fill, Stage Light disabled, Primary Light focus.\n• Empty/ErrorState: Text Light + Muted Light copy + Primary Light CTA.\n• Danger actions: Danger Light #D94A5B, never the primary teal.",
              "lineHeight": 1.5,
              "fontFamily": "Plus Jakarta Sans",
              "fontSize": 13,
              "fontWeight": "500"
            }
          ]
        },
        {
          "type": "frame",
          "id": "B7A3B6",
          "name": "Screen audit focus",
          "width": "fill_container",
          "fill": "#FFFFFF",
          "cornerRadius": 16,
          "layout": "vertical",
          "gap": 10,
          "padding": 16,
          "children": [
            {
              "type": "text",
              "id": "OpQFs",
              "name": "screensTitle",
              "fill": "#0B1718",
              "content": "Screen Audit Focus",
              "fontFamily": "Plus Jakarta Sans",
              "fontSize": 18,
              "fontWeight": "700"
            },
            {
              "type": "text",
              "id": "eJBoS",
              "name": "screensText",
              "fill": "#526264",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "Screens keep dark-mode structure and rhythm. Translate tokens role-by-role: Void → Void Light, Stage → Stage Light, Glass → Glass Light, Card → Card Light, Card High → Card High Light, Outline → Outline Light. Avoid blue legacy accents and avoid flattening all surfaces to white.",
              "lineHeight": 1.5,
              "fontFamily": "Plus Jakarta Sans",
              "fontSize": 13,
              "fontWeight": "500"
            }
          ]
        },
        {
          "type": "frame",
          "id": "OXZDM",
          "name": "Recommended order",
          "width": "fill_container",
          "fill": {
            "type": "gradient",
            "gradientType": "linear",
            "enabled": true,
            "rotation": 90,
            "size": {
              "height": 1
            },
            "colors": [
              {
                "color": "#FFFFFF",
                "position": 0
              },
              {
                "color": "#C1D7D2",
                "position": 1
              }
            ]
