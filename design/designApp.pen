          "cornerRadius": 16,
          "layout": "vertical",
          "gap": 10,
          "padding": 16,
          "children": [
            {
              "type": "text",
              "id": "JC95C",
              "name": "priorityTitle",
              "fill": "#E2E4E6",
              "content": "Recommended Order",
              "fontFamily": "Plus Jakarta Sans",
              "fontSize": 18,
              "fontWeight": "700"
            },
            {
              "type": "text",
              "id": "aalfa",
              "name": "priorityText",
              "fill": "#E2E4E6",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "1. Token governance in DESIGN.md + Pencil variables.\n2. Explore and Library differentiation.\n3. No-Line cleanup for Settings/About/Auth.\n4. Manga Detail + Reader premium layering.\n5. Runtime states and auth polish.",
              "lineHeight": 1.5,
              "fontFamily": "Plus Jakarta Sans",
              "fontSize": 13,
              "fontWeight": "600"
            }
          ]
        }
      ]
