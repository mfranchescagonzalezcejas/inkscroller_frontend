        },
        {
          "type": "frame",
          "id": "NsmJr",
          "name": "Cinematic rules",
          "width": "fill_container",
          "fill": "#1A2122",
          "cornerRadius": 16,
          "layout": "vertical",
          "gap": 10,
          "padding": 16,
          "children": [
            {
              "type": "text",
              "id": "fjMdz",
              "name": "principlesTitle",
              "fill": "#E2E4E6",
              "content": "Cinematic Canvas Rules",
              "fontFamily": "Plus Jakarta Sans",
              "fontSize": 18,
              "fontWeight": "700"
            },
            {
              "type": "text",
              "id": "NTdiY",
              "name": "principlesText",
              "fill": "#888D93",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "Artwork is protagonist; UI is the theater. Teal is the main brand color, not the whole palette. Build depth with neutrals, reserve teal for primary action/selection, use Ember Gold sparingly for editorial moments, and avoid hard divider lines.",
              "lineHeight": 1.5,
              "fontFamily": "Plus Jakarta Sans",
              "fontSize": 13,
              "fontWeight": "500"
            }
          ]
        },
        {
          "type": "frame",
          "id": "VKlxM",
          "name": "Component contracts",
          "width": "fill_container",
          "fill": "#111416",
          "cornerRadius": 16,
          "layout": "vertical",
          "gap": 10,
          "padding": 16,
          "children": [
            {
              "type": "text",
              "id": "CKSt1",
              "name": "componentsTitle",
              "fill": "#E2E4E6",
              "content": "Component Contracts to Add",
              "fontFamily": "Plus Jakarta Sans",
              "fontSize": 18,
              "fontWeight": "700"
            },
            {
              "type": "text",
              "id": "cVb8b",
              "name": "componentsText",
              "fill": "#888D93",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "• TonalTabBar: active via color/weight/surface, not underline.\n• MangaCoverCard: 2:3 cover, 16 radius, sampled glow, metadata overlay.\n• SettingsSectionCard + InfoListCard: no dividers, spacing-led rows.\n• ReaderTopBar: glass controls for normal/immersive states.\n• AuthField: default/focus/error/disabled via tonal shifts.\n• Empty/ErrorState: icon or illustration + humane copy + reusable CTA.",
              "lineHeight": 1.5,
              "fontFamily": "Plus Jakarta Sans",
              "fontSize": 13,
              "fontWeight": "500"
            }
          ]
        },
        {
          "type": "frame",
          "id": "j9ljz",
          "name": "Screen audit focus",
          "width": "fill_container",
          "fill": "#111416",
          "cornerRadius": 16,
          "layout": "vertical",
          "gap": 10,
          "padding": 16,
          "children": [
            {
              "type": "text",
              "id": "lUGy2",
              "name": "screensTitle",
              "fill": "#E2E4E6",
              "content": "Screen Audit Focus",
              "fontFamily": "Plus Jakarta Sans",
              "fontSize": 18,
              "fontWeight": "700"
            },
            {
              "type": "text",
              "id": "PGjXh",
              "name": "screensText",
              "fill": "#888D93",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "Home: fix Action tab + increase section rhythm.\nExplore: make it editorial, not a generic grid.\nLibrary: communicate ownership and progress.\nProfile: remove avatar gradient; stronger header hierarchy.\nManga Detail: richer chapter layering; normalize info blue.\nReader: glass controls + bigger reader title.\nAuth: remove hard borders; clarify gradient rule.\nSettings/About: remove 1px dividers.\nRoute Error: more premium state card and hierarchy.",
              "lineHeight": 1.5,
              "fontFamily": "Plus Jakarta Sans",
              "fontSize": 13,
              "fontWeight": "500"
            }
          ]
        },
        {
          "type": "frame",
          "id": "GZyuU",
          "name": "Recommended order",
          "width": "fill_container",
          "fill": {
            "type": "gradient",
            "gradientType": "linear",
            "enabled": true,
            "rotation": 90,
            "size": {
              "height": 1
            },
            "colors": [
