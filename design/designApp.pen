              "fontWeight": "700"
            },
            {
              "type": "text",
              "id": "cvJgi",
              "name": "platformText",
              "fill": "#888D93",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "Do not draw OS status bars in screens. Flutter owns SafeArea/AppBar/platform insets. Bottom nav remains glass: #111416 at 50% + BackdropFilter blur(32) + soft shadow + MediaQuery bottom inset. Use teal as brand action, gold as rare editorial highlight, blue only for explicit info/external states.",
              "lineHeight": 1.5,
              "fontFamily": "Plus Jakarta Sans",
              "fontSize": 13,
              "fontWeight": "500"
            }
          ]
        },
        {
          "type": "frame",
